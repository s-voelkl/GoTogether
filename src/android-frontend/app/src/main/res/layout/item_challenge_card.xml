<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="@dimen/nearby_radius"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="@dimen/border_width"
    app:strokeColor="@color/card_border"
    app:cardElevation="2dp">

    <LinearLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconBox"
            android:layout_width="68dp"
            android:layout_height="68dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/challengeEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📍"
                android:textSize="32sp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/challengeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Challenge Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:maxLines="1"
                android:ellipsize="end"
                android:letterSpacing="-0.01"/>

            <TextView
                android:id="@+id/challengeCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Category"
                android:textSize="11sp"
                android:textColor="@color/gray500"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/difficultyBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="3dp"
                    android:text="easy"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:background="@drawable/bg_badge_placeholder"/>

                <TextView
                    android:id="@+id/fullBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="3dp"
                    android:text="FULL"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#EF4444"
                    android:background="@drawable/bg_full_badge"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/challengePoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150 pts"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
