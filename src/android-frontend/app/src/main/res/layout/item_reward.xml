<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="14dp"
    android:gravity="center_vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rewardBadge"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="@dimen/border_width"
        app:strokeColor="@color/black">

        <TextView
            android:id="@+id/rewardBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="CD"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rewardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reward Title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:letterSpacing="-0.01"/>

        <TextView
            android:id="@+id/rewardSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Requirement"
            android:textSize="12sp"
            android:textColor="@color/gray500"/>
    </LinearLayout>

    <TextView
        android:id="@+id/rewardStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="Locked"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/bg_badge_placeholder"/>

</LinearLayout>
