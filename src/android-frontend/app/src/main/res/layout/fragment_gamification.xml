<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="24dp">

        <!-- Hero Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardBackgroundColor="@color/blue"
            app:strokeWidth="@dimen/border_width"
            app:strokeColor="@color/black"
            app:cardElevation="0dp"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GAMIFICATION"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:alpha="0.65"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/levelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Level 2"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:id="@+id/xpSubText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="450 XP earned from recent challenges"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:lineSpacingExtra="4dp"/>

                <View
                    android:id="@+id/progressTrack"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_progress_track"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/xpProgressText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="150/250 XP this level"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:alpha="0.75"/>

                    <TextView
                        android:id="@+id/nextLevelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next: Level 3"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:alpha="0.75"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Metrics Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="@dimen/spacing_md">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="@dimen/border_width"
                app:strokeColor="@color/black"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="G-BUCKS" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/black" android:alpha="0.65"/>
                    <TextView android:id="@+id/gbucksValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="650" android:textSize="30sp" android:textStyle="bold" android:textColor="@color/black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Digital balance" android:textSize="12sp" android:textColor="@color/gray500"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="@dimen/border_width"
                app:strokeColor="@color/black"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REWARDS" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/black" android:alpha="0.65"/>
                    <TextView android:id="@+id/rewardsSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="1/3" android:textSize="30sp" android:textStyle="bold" android:textColor="@color/black"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Unlocked so far" android:textSize="12sp" android:textColor="@color/gray500"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Rewards Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="@dimen/border_width"
            app:strokeColor="@color/black"
            app:cardElevation="0dp"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REWARDS" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/black" android:alpha="0.65"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Keep collecting" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/black"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/liveRewardsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:text="1 live"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_status_chip_ready"/>
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/rewardsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <!-- Reward items will be added here -->
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- History Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="@dimen/border_width"
            app:strokeColor="@color/black"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHALLENGE HISTORY" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/black" android:alpha="0.65"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Recent completed" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/black"/>

                <LinearLayout
                    android:id="@+id/historyList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">
                    <!-- History items will be added here -->
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
